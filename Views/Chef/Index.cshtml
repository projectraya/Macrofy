@model Macrofy.ViewModels.ChefDashboardViewModel
@{ ViewData["Title"] = "Табло на готвача"; }
<div class="dash-page">
  <div class="dash-header">
    <div style="max-width:1160px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:14px">
      <div>
        <h1>Добре дошъл, @Model.FullName</h1>
        <p>@(Model.Profile?.IsVerified == true ? "Верифициран готвач" : "Профилът ти е в процес на верификация")</p>
      </div>
      <a asp-action="EditProfile" class="btn btn-lime">Редактирай профила</a>
    </div>
  </div>
  <div class="dash-content">
    <div class="stats-grid">
      <div class="stat-card"><div class="stat-label">Клиенти</div><div class="stat-num">@Model.TotalClients</div></div>
      <div class="stat-card"><div class="stat-label">Чакащи поръчки</div><div class="stat-num">@Model.PendingOrders.Count</div></div>
      <div class="stat-card"><div class="stat-label">Активни поръчки</div><div class="stat-num">@Model.ActiveOrders.Count</div></div>
      <div class="stat-card"><div class="stat-label">Рейтинг</div><div class="stat-num">@Model.Rating.ToString("0.0")</div></div>
    </div>

    @if (Model.Profile?.IsVerified != true)
    {
      <div class="card" style="background:#fef3c7;border-color:#fcd34d;margin-bottom:22px">
        <h3 style="color:#92400e;margin-bottom:5px">Профилът ти е в процес на верификация</h3>
        <p style="font-size:.86rem;color:#78350f">Нашият екип ще прегледа профила ти скоро. Попълни биографията и специалностите си, за да ускориш процеса.</p>
      </div>
    }

    @if (Model.PendingOrders.Any())
    {
      <div class="card" style="margin-bottom:22px;border-color:#fcd34d">
        <div class="sec-hdr"><h2>Чакащи потвърждение (@Model.PendingOrders.Count)</h2></div>
        <div style="overflow-x:auto">
        <table class="tbl">
          <thead><tr><th>ID</th><th>Клиент</th><th>Период</th><th>Цена</th><th>Дата</th><th></th></tr></thead>
          <tbody>
          @foreach (var o in Model.PendingOrders)
          {
            <tr>
              <td><strong>#@o.Id</strong></td>
              <td>@o.ClientName</td>
              <td style="white-space:nowrap">@o.StartDate.ToString("dd.MM") – @o.EndDate.ToString("dd.MM.yy")</td>
              <td>@o.TotalPrice.ToString("F0") лв</td>
              <td style="font-size:.8rem;color:var(--muted)">@o.CreatedAt.ToString("dd.MM HH:mm")</td>
              <td>
                <div style="display:flex;gap:6px;flex-wrap:wrap">
                  <form asp-action="UpdateOrderStatus" method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@o.Id">
                    <input type="hidden" name="status" value="Confirmed">
                    <button type="submit" class="btn btn-primary btn-sm">Потвърди</button>
                  </form>
                  <a asp-controller="Order" asp-action="Details" asp-route-id="@o.Id" class="btn btn-secondary btn-sm">Детайли</a>
                </div>
              </td>
            </tr>
          }
          </tbody>
        </table>
        </div>
      </div>
    }

    <div class="card">
      <div class="sec-hdr"><h2>Активни поръчки</h2></div>
      @if (Model.ActiveOrders.Any())
      {
        <div style="overflow-x:auto">
        <table class="tbl">
          <thead><tr><th>ID</th><th>Клиент</th><th>Период</th><th>Статус</th><th>Цена</th><th></th></tr></thead>
          <tbody>
          @foreach (var o in Model.ActiveOrders)
          {
            <tr>
              <td><strong>#@o.Id</strong></td>
              <td>@o.ClientName</td>
              <td style="white-space:nowrap">@o.StartDate.ToString("dd.MM") – @o.EndDate.ToString("dd.MM.yy")</td>
              <td><span class="badge badge-@o.Status">@o.Status</span></td>
              <td>@o.TotalPrice.ToString("F0") лв</td>
              <td><a asp-controller="Order" asp-action="Details" asp-route-id="@o.Id" class="btn btn-ghost btn-sm">Детайли</a></td>
            </tr>
          }
          </tbody>
        </table>
        </div>
      }
      else
      {
        <div class="empty-state" style="padding:36px"><h3>Няма активни поръчки</h3><p>Когато клиенти направят поръчки, те ще се появят тук.</p></div>
      }
    </div>
  </div>
</div>
