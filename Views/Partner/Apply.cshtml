@model Macrofy.ViewModels.PartnerApplicationViewModel
@{
    ViewData["Title"] = "Партньори";
}

<div class="pub-page">

    <!-- HERO -->
    <div style="background:linear-gradient(135deg,var(--teal),var(--teal-mid));padding:80px 5% 100px;text-align:center;position:relative;overflow:hidden">
        <div style="position:absolute;top:-60px;right:-60px;width:220px;height:220px;background:rgba(141,198,63,.15);border-radius:50%"></div>
        <div style="position:absolute;bottom:-80px;left:5%;width:180px;height:180px;background:rgba(255,255,255,.04);border-radius:50%"></div>
        <div class="section-tag section-tag-dark" style="position:relative">Партньори</div>
        <h1 style="font-family:'Instrument Serif',serif;font-size:clamp(2rem,4vw,3rem);color:#fff;margin-bottom:16px;font-weight:400;position:relative">Нашите партньори</h1>
        <p style="color:rgba(255,255,255,.75);max-width:540px;margin:0 auto;font-size:.95rem;font-weight:600;position:relative">Macrofy работи с водещи организации в сферата на храненето, фитнеса и кулинарията в България.</p>
    </div>

    <!-- PARTNERS LOGOS -->
    <div style="background:#fff;padding:64px 5%">
        <div style="max-width:960px;margin:0 auto">
            <div style="text-align:center;margin-bottom:48px">
                <div class="section-tag">Официални партньори</div>
                <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.6rem,3vw,2.2rem);color:var(--teal);font-weight:400">Доверени имена, с които работим</h2>
            </div>

            <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(200px, 1fr));gap:16px" class="event-partners-grid">

                <!-- Partner Item -->
                <div style="border:2px solid var(--border);border-radius:var(--r);padding:20px;text-align:center;display:flex;flex-direction:column;justify-content:space-between;transition:all .2s" class="event-partner-item">
                    <div style="height:80px; display:flex; align-items:center; justify-content:center; margin-bottom:16px;">
                        <img src="~/images/hrcacademy.png" alt="HRC Academy" style="max-height:100%; max-width:100%; object-fit:contain;" />
                    </div>
                    <div>
                        <div style="font-weight:800;color:var(--teal);font-size:.88rem;margin-bottom:4px">HRC Culinary Academy</div>
                        <div style="font-size:.76rem;color:var(--muted);font-weight:600">Кулинарна академия</div>
                    </div>
                </div>

                <!-- Partner Item -->
                <div style="border:2px solid var(--border);border-radius:var(--r);padding:20px;text-align:center;display:flex;flex-direction:column;justify-content:space-between;transition:all .2s" class="event-partner-item">
                    <div style="height:80px; display:flex; align-items:center; justify-content:center; margin-bottom:16px;">
                        <img src="~/images/fantastico.png" alt="Fantastico" style="max-height:100%; max-width:100%; object-fit:contain;" />
                    </div>
                    <div>
                        <div style="font-weight:800;color:var(--teal);font-size:.88rem;margin-bottom:4px">Фантастико</div>
                        <div style="font-size:.76rem;color:var(--muted);font-weight:600">Хранителни продукти</div>
                    </div>
                </div>

                <!-- Partner Item -->
                <div style="border:2px solid var(--border);border-radius:var(--r);padding:20px;text-align:center;display:flex;flex-direction:column;justify-content:space-between;transition:all .2s" class="event-partner-item">
                    <div style="height:80px; display:flex; align-items:center; justify-content:center; margin-bottom:16px;">
                        <img src="~/images/myprotein.png" alt="MyProtein" style="max-height:100%; max-width:100%; object-fit:contain;" />
                    </div>
                    <div>
                        <div style="font-weight:800;color:var(--teal);font-size:.88rem;margin-bottom:4px">MyProtein</div>
                        <div style="font-size:.76rem;color:var(--muted);font-weight:600">Спортно хранене</div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- WHAT WE OFFER + FORM -->
    <div style="background:var(--bg);padding:80px 5%">
        <div style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start" class="partners-split">
            <div>
                <div class="section-tag">Стани партньор</div>
                <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.6rem,2.8vw,2.2rem);color:var(--teal);margin-bottom:14px;font-weight:400">Присъедини се към нашата мрежа</h2>
                <p style="color:var(--muted);font-size:.93rem;font-weight:600;margin-bottom:28px;line-height:1.7">Търсим кулинарни академии, хранителни компании и организации, желаещи да осигурят нови кариерни и търговски възможности.</p>
                <div class="benefits">
                    <div class="benefit">
                        <div class="b-check"><svg viewBox="0 0 10 7"><polyline points="1 3.5 3.5 6 9 1" /></svg></div>
                        <div class="b-text"><strong>Осигурете успех на талантите</strong><p>Предложете на завършилите платформа за професионално израстване и директен достъп до клиенти.</p></div>
                    </div>
                    <div class="benefit">
                        <div class="b-check"><svg viewBox="0 0 10 7"><polyline points="1 3.5 3.5 6 9 1" /></svg></div>
                        <div class="b-text"><strong>Разширете влиянието си</strong><p>Бъдете част от иновативна екосистема, трансформираща пазара на персонализирано хранене в България.</p></div>
                    </div>
                    <div class="benefit">
                        <div class="b-check"><svg viewBox="0 0 10 7"><polyline points="1 3.5 3.5 6 9 1" /></svg></div>
                        <div class="b-text"><strong>Подкрепете младежкото предприемачество</strong><p>Допринесете за развитието на иновативен Teenovator проект и кулинарната иновация.</p></div>
                    </div>
                    <div class="benefit">
                        <div class="b-check"><svg viewBox="0 0 10 7"><polyline points="1 3.5 3.5 6 9 1" /></svg></div>
                        <div class="b-text"><strong>Дългосрочно партньорство</strong><p>Изградете устойчива връзка между вашата организация и реалния пазар.</p></div>
                    </div>
                </div>
            </div>

            <div class="card" style="padding:36px;box-shadow:var(--shadow-md)">
                @if (TempData["Success"] != null)
                {
                    <div style="text-align:center;padding:20px">
                        <div style="width:60px;height:60px;background:var(--lime-faint);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;border:2px solid var(--lime)">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--lime-dark)" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12" /></svg>
                        </div>
                        <h3 style="color:var(--teal);margin-bottom:8px;font-weight:900">Благодарим!</h3>
                        <p style="color:var(--muted);font-weight:600">Получихме вашето запитване. Ще се свържем с вас скоро.</p>
                    </div>
                }
                else
                {
                    <h3 style="color:var(--teal);margin-bottom:6px;font-weight:900">Изпратете запитване</h3>
                    <p style="color:var(--muted);font-size:.84rem;font-weight:600;margin-bottom:22px">Попълнете формата и ще се свържем с вас в рамките на 48 часа.</p>
                    <div asp-validation-summary="ModelOnly" class="val-summary"></div>
                    <form asp-action="Apply" method="post">
                        @Html.AntiForgeryToken()
                        <div class="fg">
                            <label asp-for="OrganizationName">Организация</label>
                            <input asp-for="OrganizationName" placeholder="Кулинарна академия XYZ">
                            <span asp-validation-for="OrganizationName" class="fv-error"></span>
                        </div>
                        <div class="fg">
                            <label asp-for="OrganizationType">Тип организация</label>
                            <select asp-for="OrganizationType">
                                <option value="CulinaryAcademy">Кулинарна академия</option>
                                <option value="Restaurant">Ресторант / заведение</option>
                                <option value="FoodCompany">Хранителна компания</option>
                                <option value="FitnessCenter">Фитнес / уелнес център</option>
                                <option value="Other">Друго</option>
                            </select>
                        </div>
                        <div class="form-row">
                            <div class="fg">
                                <label asp-for="ContactName">Контактно лице</label>
                                <input asp-for="ContactName" placeholder="Иван Иванов">
                                <span asp-validation-for="ContactName" class="fv-error"></span>
                            </div>
                            <div class="fg">
                                <label asp-for="Phone">Телефон</label>
                                <input asp-for="Phone" placeholder="+359 88...">
                            </div>
                        </div>
                        <div class="fg">
                            <label asp-for="Email">Имейл</label>
                            <input asp-for="Email" type="email" placeholder="contact@academy.bg">
                            <span asp-validation-for="Email" class="fv-error"></span>
                        </div>
                        <div class="fg">
                            <label asp-for="Message">Съобщение</label>
                            <textarea asp-for="Message" rows="3" placeholder="Разкажете ни за вашата организация..."></textarea>
                        </div>
                        <button type="submit" class="form-submit">Изпратете запитване</button>
                    </form>
                }
            </div>
        </div>
    </div>

    <footer>
        <div class="foot-inner">
            <img src="~/images/logo.png" alt="Macrofy">
            <span>© 2025 Macrofy – Проект на Teenovator</span>
            <a asp-controller="Home" asp-action="Index">Начало</a>
        </div>
    </footer>
</div>

<style>
    .partner-logo-card:hover {
        border-color: var(--lime) !important;
        box-shadow: var(--shadow-md);
        transform: translateY(-3px);
    }
    @@media(max - width:768px) {
        .partners-logos-grid

    {
        grid-template-columns: 1fr !important;
    }

    .partners-split {
        grid-template-columns: 1fr !important;
        gap: 32px !important;
    }

}</style>