@model List<Macrofy.Models.Event>
@{
    ViewData["Title"] = "Събития";
}

<div class="dash-page" style="background:var(--bg);min-height:100vh">
    <div style="max-width:860px;margin:0 auto;padding:40px 20px 80px">

        @foreach (var ev in Model)
        {
            var spots = ev.Registrations.Count(r => r.Status != Macrofy.Models.Enum.RegistrationStatus.Rejected);
            var spotsLeft = ev.MaxSpots - spots;
            var isRegistered = User.Identity?.IsAuthenticated == true &&
            ev.Registrations.Any(r => r.UserId == (User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value));

            <div class="event-hero reveal">
                <div class="event-badge">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                    Скоро
                </div>
                <h1>@ev.Title</h1>
                <p>@ev.Description</p>
                <div class="event-meta">
                    <div class="event-meta-item">
                        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                        @ev.EventDate.ToString("dd MMMM yyyy, HH:mm", new System.Globalization.CultureInfo("bg-BG"))
                    </div>
                    <div class="event-meta-item">
                        <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
                        @ev.Location
                    </div>
                </div>
                <div class="spots-counter">
                    <span class="spots-dot"></span>
                    @if (spotsLeft > 0)
                    {
                        <span>@spotsLeft свободни места от @ev.MaxSpots</span>
                    }
                    else
                    {
                        <span style="color:var(--lime)">Местата са изчерпани</span>
                    }
                </div>
            </div>

            <!-- What to expect -->
            <div class="card reveal reveal-delay-1" style="margin-bottom:24px">
                <h2 style="font-family:'Instrument Serif',serif;font-size:1.5rem;color:var(--teal);margin-bottom:20px;font-weight:400">Какво да очакваш</h2>
                <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px" class="event-features-grid">
                    <div style="text-align:center;padding:20px;background:var(--lime-faint);border-radius:var(--r);border:1px solid rgba(141,198,63,.3)">
                        <div style="font-family:'Instrument Serif',serif;font-size:2rem;color:var(--teal);margin-bottom:6px">2–3</div>
                        <div style="font-size:.82rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.04em">Готвача на живо</div>
                    </div>
                    <div style="text-align:center;padding:20px;background:var(--teal-light);border-radius:var(--r);border:1px solid rgba(27,77,62,.15)">
                        <div style="font-family:'Instrument Serif',serif;font-size:2rem;color:var(--teal);margin-bottom:6px">10</div>
                        <div style="font-size:.82rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.04em">Участника</div>
                    </div>
                    <div style="text-align:center;padding:20px;background:var(--lime-faint);border-radius:var(--r);border:1px solid rgba(141,198,63,.3)">
                        <div style="font-family:'Instrument Serif',serif;font-size:2rem;color:var(--teal);margin-bottom:6px">100%</div>
                        <div style="font-size:.82rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.04em">Персонализирано</div>
                    </div>
                </div>
                <div style="margin-top:20px;display:flex;flex-direction:column;gap:10px">
                    <div class="benefit">
                        <div class="b-check"><svg viewBox="0 0 10 7"><polyline points="1 3.5 3.5 6 9 1" /></svg></div>
                        <div class="b-text"><strong>Персонализиран десерт по твоите макроси</strong><p>Готвачите ще приготвят специално за теб десерт, съобразен точно с твоите дневни макронутриенти.</p></div>
                    </div>
                    <div class="benefit">
                        <div class="b-check"><svg viewBox="0 0 10 7"><polyline points="1 3.5 3.5 6 9 1" /></svg></div>
                        <div class="b-text"><strong>Демонстрация на платформата</strong><p>Ще видиш как работи Macrofy на живо — от профила до заявката.</p></div>
                    </div>
                    <div class="benefit">
                        <div class="b-check"><svg viewBox="0 0 10 7"><polyline points="1 3.5 3.5 6 9 1" /></svg></div>
                        <div class="b-text"><strong>Среща с екипа и готвачите</strong><p>Ще можеш да зададеш въпроси директно на нас и на готвачите.</p></div>
                    </div>
                </div>
            </div>

            <!-- Registration card -->
            <div class="card reveal reveal-delay-2" style="border:2px solid @(spotsLeft > 0 ? "var(--lime)" : "var(--border)")">
                @if (isRegistered)
                {
                    <div style="text-align:center;padding:20px">
                        <div style="width:60px;height:60px;background:var(--lime-faint);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;border:2px solid var(--lime)">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--lime-dark)" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12" /></svg>
                        </div>
                        <h3 style="color:var(--teal);margin-bottom:6px">Вече си записан!</h3>
                        <p style="color:var(--muted);font-size:.9rem;font-weight:500">Ще получиш потвърждение на имейла си. Очакваме те!</p>
                    </div>
                }
                else if (spotsLeft <= 0)
                {
                    <div style="text-align:center;padding:20px">
                        <h3 style="color:var(--muted);margin-bottom:6px">Местата са изчерпани</h3>
                        <p style="color:var(--muted);font-size:.88rem;font-weight:500">Следи за следващо събитие.</p>
                    </div>
                }
                else
                {
                    <h3 style="color:var(--teal);margin-bottom:6px;font-size:1.1rem;font-weight:800">Запиши се за събитието</h3>
                    <p style="color:var(--muted);font-size:.86rem;margin-bottom:20px;font-weight:500">Безплатно. Само <strong style="color:var(--teal)">@spotsLeft места</strong> оставащи.</p>

                    @if (User.Identity?.IsAuthenticated != true)
                    {
                        <p style="font-size:.9rem;color:var(--muted);margin-bottom:16px;font-weight:500">Трябва да влезеш в профила си, за да се запишеш.</p>
                        <div style="display:flex;gap:10px">
                            <a asp-controller="Account" asp-action="Login" class="btn btn-primary">Вход</a>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-secondary">Регистрация</a>
                        </div>
                    }
                    else if (!User.IsInRole("Client"))
                    {
                        <p style="color:var(--muted);font-size:.88rem;font-weight:500">Само клиенти могат да се записват за събития.</p>
                    }
                    else
                    {
                        <form asp-action="Register" asp-route-id="@ev.Id" method="post">
                            @Html.AntiForgeryToken()
                            <div class="fg">
                                <label>Имейл за потвърждение</label>
                                <input type="email" name="contactEmail" value="@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value" required>
                            </div>
                            <div class="fg">
                                <label>Телефон (по желание)</label>
                                <input type="tel" name="contactPhone" placeholder="+359 88...">
                            </div>
                            <div style="background:var(--teal-light);border-radius:var(--r);padding:14px;margin-bottom:16px;font-size:.84rem;color:var(--teal);font-weight:600;border:1px solid rgba(27,77,62,.15)">
                                Твоят макро профил ще бъде споделен с готвачите, за да приготвят десерт специално за теб.
                            </div>
                            <button type="submit" class="form-submit">Запиши се безплатно</button>
                        </form>
                    }
                }
            </div>
        }

        @if (!Model.Any())
        {
            <div class="empty-state">
                <h3>Няма предстоящи събития</h3>
                <p>Следи за скоро.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        const obs = new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('on')}),{threshold:.08});
        document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));
    </script>
    <style>
        @@media(max-width:640px) {
            .event-features-grid {
                grid-template-columns: 1fr !important;
            }
        }
    </style>
}