@model List<Macrofy.ViewModels.ChefCardViewModel>
@{ ViewData["Title"] = "Готвачи"; }

<div class="dash-page">
  <div class="dash-header">
    <div style="max-width:1200px;margin:0 auto">
      <h1>Нашите готвачи 👨‍🍳</h1>
      <p>Всеки готвач е верифициран и специализиран в различни хранителни режими.</p>
    </div>
  </div>

  <div class="dash-content">
    <!-- Filters -->
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:24px">
      <a asp-action="Chefs" class="btn @(ViewBag.CurrentSpecialty == null ? "btn-primary" : "btn-secondary") btn-sm">Всички</a>
      @foreach (var sp in Enum.GetValues<Macrofy.Models.Enum.ChefSpecialty>())
      {
        var label = sp switch {
          Macrofy.Models.Enum.ChefSpecialty.SportNutrition => "Спортно хранене",
          Macrofy.Models.Enum.ChefSpecialty.Keto => "Кето",
          Macrofy.Models.Enum.ChefSpecialty.Vegan => "Веганска",
          Macrofy.Models.Enum.ChefSpecialty.Mediterranean => "Средиземноморска",
          Macrofy.Models.Enum.ChefSpecialty.WeightLoss => "Отслабване",
          _ => "Обща"
        };
        <a asp-action="Chefs" asp-route-specialty="@sp.ToString()"
           class="btn @(ViewBag.CurrentSpecialty == sp.ToString() ? "btn-primary" : "btn-secondary") btn-sm">@label</a>
      }
    </div>

    @if (Model.Any())
    {
      <div class="chef-grid">
        @foreach (var chef in Model)
        {
          <div class="chef-card">
            <div class="chef-card-top">
              <div class="chef-avatar-wrap">👨‍🍳</div>
              <h3>@chef.FullName</h3>
              <div class="specialty-label">@chef.Specialties</div>
            </div>
            <div class="chef-card-body">
              <p class="chef-bio">@chef.Bio</p>
              <div class="chef-meta">
                <div class="chef-rating"><span class="star-icon">★</span> @chef.Rating.ToString("0.0") (@chef.TotalReviews оценки)</div>
                <div class="chef-rate">@chef.HourlyRate лв/ч</div>
              </div>
              @if (!string.IsNullOrEmpty(chef.Location))
              {
                <div style="font-size:.78rem;color:var(--muted);margin-bottom:10px">📍 @chef.Location</div>
              }
              <div style="font-size:.78rem;color:var(--muted);margin-bottom:10px">🏆 @chef.ExperienceYears год. опит</div>
              <div class="@("avail-dot" + (chef.IsAvailable ? "" : " off"))">
                @(chef.IsAvailable ? "Наличен за нови клиенти" : "Зает в момента")
              </div>
              @if (chef.IsVerified)
              {
                <div style="font-size:.75rem;color:var(--lime);font-weight:700;margin-bottom:14px">✓ Верифициран готвач</div>
              }
              @if (chef.IsAvailable)
              {
                <a asp-controller="Order" asp-action="Create" asp-route-chefId="@chef.Id"
                   class="btn btn-primary btn-sm" style="width:100%">Поръчай при @chef.FullName.Split(' ')[0] →</a>
              }
              else
              {
                <button class="btn btn-secondary btn-sm" style="width:100%" disabled>Зает в момента</button>
              }
            </div>
          </div>
        }
      </div>
    }
    else
    {
      <div class="empty-state">
        <div class="empty-icon">👨‍🍳</div>
        <h3>Няма намерени готвачи</h3>
        <p>Опитай с друга специализация.</p>
        <a asp-action="Chefs" class="btn btn-primary">Виж всички</a>
      </div>
    }
  </div>
</div>
