@model List<Macrofy.ViewModels.ChefCardViewModel>
@{
    ViewData["Title"] = "Готвачи";
}

<div class="dash-page">
    <div class="dash-header">
        <div style="max-width:1160px;margin:0 auto">
            <h1>Нашите готвачи</h1>
            <p>Всеки готвач е верифициран и специализиран в различни хранителни режими.</p>
        </div>
    </div>
    <div class="dash-content">

        <!-- Filter bar -->
        <div class="card" style="margin-bottom:22px;padding:20px">
            <form method="get" asp-action="Chefs" id="filterForm" style="display:flex;flex-wrap:wrap;gap:14px;align-items:flex-end">
                <div style="flex:1;min-width:180px">
                    <label style="display:block;font-size:.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:5px">Специализация</label>
                    <select name="specialty" class="fg" style="width:100%;padding:9px 12px;border:1.5px solid var(--border);border-radius:var(--rs);font-size:.88rem;font-family:'Nunito',sans-serif;background:#fff;outline:none" onchange="this.form.submit()">
                        <option value="">Всички специализации</option>
                        @foreach (var sp in Enum.GetValues<Macrofy.Models.Enum.ChefSpecialty>())
                        {
                            var label = sp switch
                            {
                                Macrofy.Models.Enum.ChefSpecialty.SportNutrition => "Спортно хранене",
                                Macrofy.Models.Enum.ChefSpecialty.Keto => "Кето",
                                Macrofy.Models.Enum.ChefSpecialty.Vegan => "Веганска кухня",
                                Macrofy.Models.Enum.ChefSpecialty.Mediterranean => "Средиземноморска",
                                Macrofy.Models.Enum.ChefSpecialty.WeightLoss => "Отслабване",
                                _ => "Обща здравословна"
                            };
                            <option value="@sp" selected="@(ViewBag.FilterSpecialty?.ToString() == sp.ToString() ? "selected" : null)">
                                @label
                            </option>
                        }
                    </select>
                </div>

                <div style="flex:1;min-width:140px">
                    <label style="display:block;font-size:.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:5px">Наличност</label>
                    <select name="available" style="width:100%;padding:9px 12px;border:1.5px solid var(--border);border-radius:var(--rs);font-size:.88rem;font-family:'Nunito',sans-serif;background:#fff;outline:none" onchange="this.form.submit()">
                        <option value="">Всички</option>
                        <option value="true" selected="@(ViewBag.FilterAvailable?.ToString() == "True" ? "selected" : null)">Само налични</option>
                    </select>
                </div>

                <div style="flex:1;min-width:140px">
                    <label style="display:block;font-size:.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:5px">Сортирай по</label>
                    <select name="sortBy" style="width:100%;padding:9px 12px;border:1.5px solid var(--border);border-radius:var(--rs);font-size:.88rem;font-family:'Nunito',sans-serif;background:#fff;outline:none" onchange="this.form.submit()">
                        <option value="rating" selected="@(ViewBag.FilterSortBy?.ToString() == "rating" ? "selected" : null)">Рейтинг</option>
                        <option value="experience" selected="@(ViewBag.FilterSortBy?.ToString() == "experience" ? "selected" : null)">Опит</option>
                        <option value="price_asc" selected="@(ViewBag.FilterSortBy?.ToString() == "price_asc" ? "selected" : null)">Цена (ниска към висока)</option>
                        <option value="price_desc" selected="@(ViewBag.FilterSortBy?.ToString() == "price_desc" ? "selected" : null)">Цена (висока към ниска)</option>
                    </select>
                </div>

                @if (ViewBag.FilterSpecialty != null || ViewBag.FilterAvailable != null)
                {
                    <a asp-action="Chefs" class="btn btn-secondary btn-sm" style="align-self:flex-end">Изчисти филтрите</a>
                }
            </form>
            <div style="margin-top:12px;font-size:.8rem;color:var(--muted)">Намерени: <strong style="color:var(--dark)">@Model.Count готвача</strong></div>
        </div>

        @if (Model.Any())
        {
            <div class="chef-grid">
                @foreach (var c in Model)
                {
                    <div class="chef-card">
                        <div class="chef-card-head">
                            <div class="chef-initials">@c.FullName[0]</div>
                            <h3>@c.FullName</h3>
                            <div class="chef-spec">@c.Specialties</div>
                        </div>
                        <div class="chef-card-body">
                            <p class="chef-bio">@c.Bio</p>
                            <div class="chef-meta">
                                <div class="chef-rating"><span class="star">★</span> @c.Rating.ToString("0.0") (@c.TotalReviews оценки)</div>
                                <div class="chef-rate">@c.HourlyRate лв/ч</div>
                            </div>
                            @if (!string.IsNullOrEmpty(c.Location))
                            {
                                <div style="font-size:.76rem;color:var(--muted);margin-bottom:8px">@c.Location · @c.ExperienceYears г. опит</div>
                            }
                            @if (c.IsVerified)
                            {
                                <div class="chef-verified">Верифициран готвач</div>
                            }
                            <div class="@("chef-avail" + (c.IsAvailable ? "" : " unavail"))">@(c.IsAvailable ? "Наличен за нови клиенти" : "Зает в момента")</div>
                            @if (c.IsAvailable)
                            {
                                <a asp-controller="Order" asp-action="Create" asp-route-chefId="@c.Id" class="btn btn-primary btn-sm btn-full">Поръчай</a>
                            }
                            else
                            {
                                <button class="btn btn-secondary btn-sm btn-full" disabled>Зает в момента</button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <h3>Няма намерени готвачи</h3>
                <p>Опитай с по-широки критерии за търсене.</p>
                <a asp-action="Chefs" class="btn btn-primary btn-sm">Изчисти филтрите</a>
            </div>
        }
    </div>
</div>