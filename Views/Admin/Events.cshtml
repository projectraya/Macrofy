@model List<Macrofy.Models.Event>
@{
    ViewData["Title"] = "Управление на събития";
}
<style>
    .tbl {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed; 
    }

        .tbl th,
        .tbl td {
            padding: 14px 16px;
            text-align: left;
            vertical-align: top;
            word-wrap: break-word;
            overflow-wrap: break-word;
            white-space: normal;
        }

            .tbl th:nth-child(1),
            .tbl td:nth-child(1) {
                width: 50px;
            }

            .tbl th:nth-child(2),
            .tbl td:nth-child(2) {
                width: 180px;
            }

            .tbl th:nth-child(3),
            .tbl td:nth-child(3) {
                width: 180px;
            }

            .tbl th:nth-child(4),
            .tbl td:nth-child(4) {
                width: 140px;
            }

            .tbl th:nth-child(5),
            .tbl td:nth-child(5) {
                width: 200px;
            }

            .tbl th:nth-child(6),
            .tbl td:nth-child(6) {
                width: 160px;
            }

            .tbl th:nth-child(7),
            .tbl td:nth-child(7) {
                width: 220px;
            }

            .tbl th:nth-child(8),
            .tbl td:nth-child(8) {
                width: 120px;
            }

            .tbl th:nth-child(9),
            .tbl td:nth-child(9) {
                width: 140px;
            }

            .tbl th:nth-child(10),
            .tbl td:nth-child(10) {
                width: 160px;
            }

    .user-cell {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

        .user-cell .name {
            font-weight: 700;
            color: var(--teal);
        }

        .user-cell .email {
            font-size: 0.75rem;
            color: var(--muted);
        }
</style>

<div class="dash-page">
    <div class="dash-header">
        <div style="max-width:1200px; margin:0 auto; display:flex; justify-content:space-between; align-items:flex-end; gap:20px">
            <div>
                <h1>Управление на събития</h1>
                <p>Преглед на кандидатурите и ръчно управление на потвърдените места.</p>
            </div>
            <!-- Бутонът Добави събитие вляво под заглавието -->
            <div style="padding-bottom: 5px;">
                <a asp-action="CreateEvent" class="btn btn-primary">
                    <span style="margin-right:5px">+</span> Добави събитие
                </a>
            </div>
        </div>
    </div>

    <div class="dash-content">
        @foreach (var ev in Model)
        {
            <div class="card" style="margin-bottom:28px; position:relative">

                
                <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:24px; margin-bottom:24px; padding-bottom:20px; border-bottom:1px solid var(--border)">
                    <div style="flex:1; min-width:300px">
                        <h2 style="color:var(--teal); font-size:1.3rem; margin-bottom:8px; padding-right:150px">@ev.Title</h2>
                        <div style="font-size:.84rem; color:var(--muted); font-weight:600; margin-bottom:12px">
                            @ev.EventDate.ToString("dd.MM.yyyy HH:mm") &nbsp;·&nbsp; @ev.Location
                        </div>
                        <!-- Редактирай / Изтрий - Изнесени тук, за да не пречат -->
                        <div style="display:flex; gap:8px; flex-shrink:0">
                            <a asp-action="EditEvent" asp-route-id="@ev.Id" class="btn btn-sm btn-secondary" style="font-size:0.75rem; padding:6px 12px; border:1px solid var(--border)">Редактирай</a>

                            <form asp-action="DeleteEvent" method="post" onsubmit="return confirm('Сигурен ли си?')" style="margin:0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@ev.Id" />
                                <button type="submit" class="btn btn-sm btn-danger" style="font-size:0.75rem; padding:6px 12px">Изтрий</button>
                            </form>
                        </div>
                        <br />
                        <div style="display:flex; gap:10px; flex-wrap:wrap">
                            <span class="badge" style="background:var(--lime-faint); color:var(--teal); border:1px solid rgba(141,198,63,0.2)">
                                @ev.Registrations.Count кандидатури
                            </span>
                            <span class="badge" style="background:var(--teal-light); color:var(--teal)">
                                @ev.ConfirmedSpots / @ev.MaxSpots потвърдени
                            </span>
                        </div>
                    </div>

                    <!-- По-подредена форма за местата -->
                    <div style="background:var(--bg); border-radius:var(--r); padding:20px; border:1px solid var(--border); width:280px">
                        <div style="font-size:.7rem; font-weight:900; color:var(--teal); text-transform:uppercase; letter-spacing:.05em; margin-bottom:12px">
                            Места за събитието
                        </div>

                        <form asp-action="UpdateEventSpots" method="post" style="display:flex; flex-direction:column; gap:10px">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="eventId" value="@ev.Id">

                            <div style="display:flex; align-items:center; gap:10px; background:#fff; padding:6px 12px; border-radius:8px; border:1px solid var(--border)">
                                <input type="number" name="confirmedSpots"
                                       value="@ev.ConfirmedSpots"
                                       min="0" max="@ev.MaxSpots"
                                       style="width:60px; border:none; font-weight:800; font-size:1.1rem; color:var(--teal); outline:none; text-align:center">
                                <span style="color:var(--muted); font-size:0.9rem; font-weight:600">/ @ev.MaxSpots потвърдени</span>
                            </div>

                            <button type="submit" class="btn btn-primary btn-sm" style="width:100%; padding:10px">Запази промените</button>
                        </form>
                        <div style="font-size:.74rem;color:var(--muted);margin-top:7px;font-weight:600">
                            Потвърдените места се показват публично като "свободни".
                        </div>
                    </div>
                </div>

                <!-- Applications table -->
                @if (ev.Registrations.Any())
                {
                    <div style="overflow-x:auto">
                        <table class="tbl">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Участник</th>
                                    <th>Имейл</th>
                                    <th>Телефон</th>
                                    <th>Макро профил</th>
                                    <th>Алергии</th>
                                    <th>Хранителни предпочитания</th>
                                    <th>Статус</th>
                                    <th>Кандидатствал на</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int rowNum = 1;
                                }
                                @foreach (var r in ev.Registrations.OrderBy(r => r.RegisteredAt))
                                {
                                    <tr>
                                        <td style="color:var(--muted);font-weight:700">@(rowNum++)</td>
                                        <td>
                                            <div class="user-cell">
                                                <span class="name">@r.User.FullName</span>
                                                <span class="email">@r.User.Email</span>
                                            </div>
                                        </td>
                                        <td>@r.ContactEmail</td>
                                        <td style="color:var(--muted)">@(r.ContactPhone ?? "–")</td>
                                        <td>
                                            @if (r.User.DailyCalories.HasValue)
                                            {
                                                <div style="font-size:.78rem;line-height:1.6">
                                                    <strong style="color:var(--teal)">@r.User.DailyCalories ккал</strong><br>
                                                    П: @r.User.DailyProtein г &nbsp;|&nbsp;
                                                    В: @r.User.DailyCarbs г &nbsp;|&nbsp;
                                                    М: @r.User.DailyFat г
                                                </div>
                                            }
                                            else
                                            {
                                                <span style="color:var(--danger);font-size:.78rem;font-weight:700">Не е попълнен</span>
                                            }
                                        </td>
                                        <td style="font-size:.78rem;max-width:160px">
                                            @if (!r.User.HasAllergies)
                                            {
                                                <span style="color:var(--lime-dark);font-weight:700">Без алергии</span>
                                            }
                                            else if (!string.IsNullOrEmpty(r.User.AllergyList))
                                            {
                                                <span style="color:var(--danger)">@r.User.AllergyList</span>
                                            }
                                            else
                                            {
                                                <span style="color:var(--muted)">–</span>
                                            }
                                        </td>
                                        <td style="font-size:.76rem;max-width:200px;color:var(--muted)">
                                            @if (!string.IsNullOrEmpty(r.User.FavProteins))
                                            {
                                                <div><strong style="color:var(--teal)">П:</strong> @r.User.FavProteins</div>
                                            }
                                            @if (!string.IsNullOrEmpty(r.User.FavCarbs))
                                            {
                                                <div><strong style="color:var(--teal)">В:</strong> @r.User.FavCarbs</div>
                                            }
                                            @if (!string.IsNullOrEmpty(r.User.FavFats))
                                            {
                                                <div><strong style="color:var(--teal)">М:</strong> @r.User.FavFats</div>
                                            }
                                            @if (!string.IsNullOrEmpty(r.User.CheatMeal))
                                            {
                                                <div><strong style="color:var(--teal)">Cheat:</strong> @r.User.CheatMeal</div>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge badge-@r.Status.ToString()"
                                                  style="background:@(r.Status==Macrofy.Models.Enum.RegistrationStatus.Confirmed?"#d1fae5":r.Status==Macrofy.Models.Enum.RegistrationStatus.Rejected?"#fee2e2":"#fef3c7");color:@(r.Status==Macrofy.Models.Enum.RegistrationStatus.Confirmed?"#065f46":r.Status==Macrofy.Models.Enum.RegistrationStatus.Rejected?"#991b1b":"#92400e")">
                                                @(r.Status switch
                                                {
                                                    Macrofy.Models.Enum.RegistrationStatus.Confirmed => "Потвърден",
                                                    Macrofy.Models.Enum.RegistrationStatus.Rejected => "Отказан",
                                                    _ => "Изчаква"
                                                })
                                            </span>
                                        </td>
                                        <td style="font-size:.78rem;color:var(--muted);white-space:nowrap">
                                            @r.RegisteredAt.ToString("dd.MM.yy HH:mm")
                                        </td>
                                        <td>
                                            <div style="display:flex;gap:6px;flex-wrap:wrap">
                                                @if (r.Status != Macrofy.Models.Enum.RegistrationStatus.Confirmed)
                                                {
                                                    <form asp-action="UpdateRegistration" method="post" style="display:inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@r.Id">
                                                        <input type="hidden" name="status" value="Confirmed">
                                                        <button type="submit" class="btn btn-primary btn-sm">Потвърди</button>
                                                    </form>
                                                }
                                                @if (r.Status != Macrofy.Models.Enum.RegistrationStatus.Rejected)
                                                {
                                                    <form asp-action="UpdateRegistration" method="post" style="display:inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@r.Id">
                                                        <input type="hidden" name="status" value="Rejected">
                                                        <button type="submit" class="btn btn-danger btn-sm">Откажи</button>
                                                    </form>
                                                }
                                                @if (r.Status == Macrofy.Models.Enum.RegistrationStatus.Pending)
                                                {
                                                    <span style="font-size:.75rem;color:var(--muted);font-weight:600;align-self:center">изчаква</span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state" style="padding:32px">
                        <h3>Няма кандидатури все още</h3>
                        <p>Когато хора кандидатстват, ще се появят тук.</p>
                    </div>
                }

            </div>
        }
    </div>
</div>