@model List<Macrofy.Models.PartnerApplication>
@{ ViewData["Title"] = "Партньорски заявки"; }

<style>
    .partners-table {
        table-layout: fixed;
        width: 100%;
    }

        .partners-table th,
        .partners-table td {
            padding: 16px 18px;
            vertical-align: middle;
        }

            .partners-table th:nth-child(1),
            .partners-table td:nth-child(1) {
                width: 25%;
            }

            .partners-table th:nth-child(2),
            .partners-table td:nth-child(2) {
                width: 15%;
            }

            .partners-table th:nth-child(3),
            .partners-table td:nth-child(3) {
                width: 25%;
            }

            .partners-table th:nth-child(4),
            .partners-table td:nth-child(4) {
                width: 10%;
            }

            .partners-table th:nth-child(5),
            .partners-table td:nth-child(5) {
                width: 10%;
            }

            .partners-table th:nth-child(6),
            .partners-table td:nth-child(6) {
                width: 15%;
            }

        .partners-table td {
            word-wrap: break-word;
            white-space: normal;
        }

            /* малко polish */
            .partners-table td:nth-child(2) {
                color: var(--muted);
            }

            .partners-table td:nth-child(3) {
                line-height: 1.4;
            }
</style>
<div class="dash-page">
  <div class="dash-header">
    <div style="max-width:1200px;margin:0 auto">
      <h1>Партньорски заявки (@Model.Count)</h1>
    </div>
  </div>
  <div class="dash-content">
    @if (Model.Any())
    {
      <div class="card" style="padding:0;overflow:hidden">
          <table class="tbl partners-table">
          <thead><tr><th>Организация</th><th>Тип</th><th>Контакт</th><th>Статус</th><th>Дата</th><th>Действия</th></tr></thead>
          <tbody>
          @foreach (var p in Model)
          {
            <tr>
              <td>
                <div style="font-weight:600">@p.OrganizationName</div>
                <div style="font-size:.78rem;color:var(--muted)">@p.ContactName</div>
              </td>
              <td style="font-size:.85rem">@p.OrganizationType</td>
              <td>
                  <div style="max-width:260px">
                      <div style="font-size:.82rem">@p.Email</div>
                      @if (!string.IsNullOrEmpty(p.Phone))
                      {
                          <div style="font-size:.78rem;color:var(--muted)">
                              @p.Phone
                          </div>
                      }
                  </div>
              </td>
              <td>
                <span class="badge @(p.Status == Macrofy.Models.Enum.PartnerStatus.Approved ? "badge-Confirmed" : p.Status == Macrofy.Models.Enum.PartnerStatus.Rejected ? "badge-Cancelled" : "badge-Pending")">
                  @p.Status
                </span>
              </td>
              <td style="font-size:.82rem;color:var(--muted)">@p.CreatedAt.ToString("dd.MM.yyyy")</td>
              <td>
                @if (p.Status == Macrofy.Models.Enum.PartnerStatus.Pending)
                {
                  <div style="display:flex;gap:6px">
                    <form asp-action="UpdatePartnerStatus" method="post" style="display:inline">
                      @Html.AntiForgeryToken()
                      <input type="hidden" name="id" value="@p.Id">
                      <input type="hidden" name="status" value="Approved">
                      <button type="submit" class="btn btn-primary btn-sm">✓ Одобри</button>
                    </form>
                    <form asp-action="UpdatePartnerStatus" method="post" style="display:inline">
                      @Html.AntiForgeryToken()
                      <input type="hidden" name="id" value="@p.Id">
                      <input type="hidden" name="status" value="Rejected">
                      <button type="submit" class="btn btn-danger btn-sm">✕</button>
                    </form>
                  </div>
                }
              </td>
            </tr>
          }
          </tbody>
        </table>
      </div>
    }
    else
    {
      <div class="empty-state"><div class="empty-icon">🤝</div><h3>Няма партньорски заявки</h3></div>
    }
  </div>
</div>
