<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " – " : "")Macrofy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<nav class="navbar" id="navbar">
  <div class="nav-inner">
    <a class="nav-brand" asp-controller="Home" asp-action="Index">
      <img src="~/images/logo.png" alt="Macrofy" />
    </a>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
      <div class="nav-links">
        @if (User.IsInRole("Client"))
        {
          <a asp-controller="Dashboard" asp-action="Index" class="nav-link">Начало</a>
          <a asp-controller="Dashboard" asp-action="Chefs" class="nav-link">Готвачи</a>
          <a asp-controller="Dashboard" asp-action="Orders" class="nav-link">Поръчки</a>
          <a asp-controller="Dashboard" asp-action="MacroProfile" class="nav-link">Макро профил</a>
        }
        else if (User.IsInRole("Chef"))
        {
          <a asp-controller="Chef" asp-action="Index" class="nav-link">Табло</a>
          <a asp-controller="Chef" asp-action="EditProfile" class="nav-link">Моят профил</a>
          <a asp-controller="Chef" asp-action="Clients" class="nav-link">Клиенти</a>
        }
        else if (User.IsInRole("Admin"))
        {
          <a asp-controller="Admin" asp-action="Index" class="nav-link">Табло</a>
          <a asp-controller="Admin" asp-action="Chefs" class="nav-link">Готвачи</a>
          <a asp-controller="Admin" asp-action="Users" class="nav-link">Потребители</a>
          <a asp-controller="Admin" asp-action="Partners" class="nav-link">Партньори</a>
        }
      </div>
      <div class="nav-user">
        <button class="nav-avatar" id="avatarBtn">@(User.Identity.Name?.Substring(0,1).ToUpper())</button>
        <div class="nav-dropdown" id="navDropdown">
          <div class="nav-dropdown-name">@User.Identity.Name</div>
          <form asp-controller="Account" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="nav-dropdown-btn">Изход</button>
          </form>
        </div>
      </div>
    }
    else
    {
      <div class="nav-links">
        <a href="#problem" class="nav-link">Как работи</a>
        <a href="#chefs" class="nav-link">Готвачи</a>
        <a asp-controller="Partner" asp-action="Apply" class="nav-link">Партньори</a>
      </div>
      <div class="nav-auth">
        <a asp-controller="Account" asp-action="Login" class="btn btn-ghost btn-sm">Вход</a>
        <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm">Регистрация</a>
      </div>
    }
    <button class="nav-ham" id="navHam" aria-label="Меню">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<div class="mob-menu" id="mobMenu">
  @if (User.Identity != null && User.Identity.IsAuthenticated)
  {
    @if (User.IsInRole("Client"))
    {
      <a asp-controller="Dashboard" asp-action="Index">Начало</a>
      <a asp-controller="Dashboard" asp-action="Chefs">Готвачи</a>
      <a asp-controller="Dashboard" asp-action="Orders">Поръчки</a>
      <a asp-controller="Dashboard" asp-action="MacroProfile">Макро профил</a>
    }
    else if (User.IsInRole("Chef"))
    {
      <a asp-controller="Chef" asp-action="Index">Табло</a>
      <a asp-controller="Chef" asp-action="EditProfile">Моят профил</a>
      <a asp-controller="Chef" asp-action="Clients">Клиенти</a>
    }
    else if (User.IsInRole("Admin"))
    {
      <a asp-controller="Admin" asp-action="Index">Табло</a>
      <a asp-controller="Admin" asp-action="Chefs">Готвачи</a>
      <a asp-controller="Admin" asp-action="Users">Потребители</a>
    }
    <form asp-controller="Account" asp-action="Logout" method="post" style="margin-top:8px">
      @Html.AntiForgeryToken()
      <button type="submit" class="btn btn-primary btn-full">Изход</button>
    </form>
  }
  else
  {
    <a asp-controller="Account" asp-action="Login">Вход</a>
    <a asp-controller="Account" asp-action="Register" style="font-weight:700;color:var(--dark)">Регистрация</a>
  }
</div>

@if (TempData["Success"] != null)
{
  <div class="toast toast-success" id="toast">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
  <div class="toast toast-error" id="toast">@TempData["Error"]</div>
}

<main>@RenderBody()</main>

<script>
window.addEventListener('scroll',()=>document.getElementById('navbar').classList.toggle('scrolled',window.scrollY>20));
document.getElementById('navHam')?.addEventListener('click',()=>document.getElementById('mobMenu').classList.toggle('open'));
document.getElementById('avatarBtn')?.addEventListener('click',e=>{e.stopPropagation();document.getElementById('navDropdown')?.classList.toggle('show');});
document.addEventListener('click',()=>document.getElementById('navDropdown')?.classList.remove('show'));
const t=document.getElementById('toast');
if(t)setTimeout(()=>t.classList.add('hide'),4500);
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
